<%- layout("/layouts/boilerplate") %>

<div class="auth-container mt-0">
  <div class="auth-image-side">
    <img src="https://images.unsplash.com/photo-1506461883276-594a12b11cf3?q=80&w=2070&auto=format&fit=crop" alt="Travel">
    <div class="auth-image-overlay">
      <h1 class="display-4 fw-bold mb-3">Your next story <br>begins here.</h1>
      <p class="fs-5 text-light-50">Discover unique stays and unforgettable experiences across India.</p>
    </div>
  </div>
  
  <div class="auth-form-side">
    <div class="auth-card fade-in">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-2">Welcome Back</h2>
        <p class="text-muted">Sign in to manage your stays and bookings</p>
      </div>

      <form action="/signin" method="POST" class="needs-validation" novalidate>
        <div class="form-floating mb-3">
          <input
            name="username"
            type="text"
            class="form-control bg-light border-0 shadow-none px-4"
            id="usernameInput"
            placeholder="Username"
            required
          />
          <label for="usernameInput" class="px-4">Username</label>
          <div class="invalid-feedback">Required field.</div>
        </div>

        <div class="form-floating mb-4 position-relative">
          <input
            name="password"
            type="password"
            class="form-control bg-light border-0 shadow-none px-4"
            id="passwordInput"
            placeholder="Password"
            required
          />
          <label for="passwordInput" class="px-4">Password</label>
          <span class="password-toggle">
            <i class="fa-solid fa-eye"></i>
          </span>
          <div class="invalid-feedback">Required field.</div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <div class="form-check">
            <input class="form-check-input shadow-none" type="checkbox" id="rememberMe">
            <label class="form-check-label small text-muted" for="rememberMe">Remember me</label>
          </div>
          <a href="#" class="small text-primary text-decoration-none">Forgot Password?</a>
        </div>

        <button class="btn btn-primary-custom w-100 py-3 fw-bold rounded-pill mb-4 shadow-sm">
          Continue
        </button>
      </form>

      <div class="text-center">
        <p class="text-muted small">New to TripTales? <a href="/signup" class="text-primary text-decoration-none fw-bold">Create an account</a></p>
      </div>
    </div>
  </div>
</div>

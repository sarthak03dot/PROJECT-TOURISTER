<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5 fade-in">
  <div class="col-lg-10 offset-lg-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold">Welcome back, <%= currUser.username %>!</h2>
      <a href="/listings/new" class="btn btn-primary-custom shadow-sm">
        <i class="fa-solid fa-plus me-2"></i>Create New Listing
      </a>
    </div>

    <!-- Stats Summary -->
    <div class="row g-3 mb-5">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius); background: linear-gradient(135deg, var(--primary), #a855f7);">
          <h1 class="display-4 fw-bold text-white mb-0"><%= bookings.length %></h1>
          <p class="text-white opacity-75 mb-0">Total Bookings</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius); background: linear-gradient(135deg, var(--secondary), #f43f5e);">
          <h1 class="display-4 fw-bold text-white mb-0"><%= listings.length %></h1>
          <p class="text-white opacity-75 mb-0">Your Listings</p>
        </div>
      </div>
       <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius); background: #f8fafc;">
          <h1 class="display-4 fw-bold text-dark mb-0"><%= bookings.reduce((acc, b) => acc + b.totalPrice, 0) %></h1>
          <p class="text-muted mb-0">Total Spent ($)</p>
        </div>
      </div>
    </div>

    <!-- My Wishlist -->
    <div class="mb-5">
      <h4 class="fw-bold mb-4">Your Wishlist</h4>
      <% if (wishlist && wishlist.length > 0) { %>
        <div class="row g-4 overflow-x-auto pb-3 flex-nowrap hide-scrollbar">
          <% for(let item of wishlist) { %>
            <div class="col-md-4" style="min-width: 300px;">
              <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: var(--radius);">
                <img src="<%= (item.image && item.image.url) ? item.image.url : 'https://images.unsplash.com/photo-1580041066704-46c307477c5f?q=80&w=1170&auto=format&fit=crop' %>" class="card-img-top" style="height: 160px; object-fit: cover;" alt="Wishlist Item">
                <div class="card-body">
                  <h6 class="fw-bold mb-1 text-truncate"><%= item.title %></h6>
                  <p class="text-muted small mb-2"><%= item.location %></p>
                  <a href="/listings/<%= item._id %>" class="btn btn-sm btn-outline-primary w-100 rounded-pill">View Stay</a>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-center py-4 border rounded-4 bg-white">
          <p class="text-muted mb-0">No saved places yet. Start exploring!</p>
        </div>
      <% } %>
    </div>

    <!-- My Bookings -->
    <div class="mb-5">
      <h4 class="fw-bold mb-4">Your Recent Reservations</h4>
      <% if (bookings.length > 0) { %>
        <div class="row g-4">
          <% for(let booking of bookings) { %>
            <div class="col-md-6">
              <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: var(--radius);">
                <div class="row g-0">
                  <div class="col-4">
                    <img src="<%= (booking.listing && booking.listing.image && booking.listing.image.url) ? booking.listing.image.url : 'https://images.unsplash.com/photo-1580041066704-46c307477c5f?q=80&w=1170&auto=format&fit=crop' %>" class="img-fluid h-100 object-fit-cover" alt="Property">
                  </div>
                  <div class="col-8">
                    <div class="card-body">
                      <h6 class="fw-bold mb-1 text-truncate" data-label="Property"><%= booking.listing ? booking.listing.title : 'Deleted Property' %></h6>
                      <p class="text-muted small mb-2" data-label="Dates"><i class="fa-solid fa-calendar me-2"></i><%= new Date(booking.checkIn).toLocaleDateString() %> - <%= new Date(booking.checkOut).toLocaleDateString() %></p>
                      <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-light text-primary border px-2 py-1" data-label="Status"><%= booking.status %></span>
                        <span class="fw-bold text-success" data-label="Total">$<%= booking.totalPrice %></span>
                      </div>
                      <% if (booking.listing) { %>
                        <a href="/listings/<%= booking.listing._id %>" class="btn btn-link p-0 mt-2 small text-decoration-none">View Details <i class="fa-solid fa-arrow-right ms-1"></i></a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-center py-5 bg-light rounded-4">
          <p class="text-muted mb-3">You haven't made any reservations yet.</p>
          <a href="/listings" class="btn btn-outline-primary rounded-pill">Explore stays</a>
        </div>
      <% } %>
    </div>

    <!-- Incoming Reservations (Host View) -->
    <div class="mb-5">
      <h4 class="fw-bold mb-4">Incoming Reservations (Host View)</h4>
      <% if (incomingBookings.length > 0) { %>
        <div class="table-responsive bg-white shadow-sm p-3 rounded-4">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="border-0">Guest</th>
                <th class="border-0">Property</th>
                <th class="border-0">Dates</th>
                <th class="border-0">Earnings</th>
                <th class="border-0">Status</th>
              </tr>
            </thead>
            <tbody>
              <% for(let booking of incomingBookings) { %>
                <tr>
                  <td data-label="Guest">
                    <div class="d-flex align-items-center gap-2">
                       <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.75rem;">
                        <%= booking.guest.username.charAt(0).toUpperCase() %>
                      </div>
                      <span class="fw-semibold">@<%= booking.guest.username %></span>
                    </div>
                  </td>
                  <td data-label="Property"><span class="text-truncate d-inline-block" style="max-width: 150px;"><%= booking.listing ? booking.listing.title : 'Deleted Property' %></span></td>
                  <td data-label="Dates" class="small text-muted"><%= new Date(booking.checkIn).toLocaleDateString() %> - <%= new Date(booking.checkOut).toLocaleDateString() %></td>
                  <td data-label="Earnings" class="fw-bold text-success">$<%= booking.totalPrice %></td>
                  <td data-label="Status"><span class="badge bg-success-subtle text-success border-success-subtle px-2"><%= booking.status %></span></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-4 bg-light rounded-4">
          <p class="text-muted mb-0">No incoming reservations yet.</p>
        </div>
      <% } %>
    </div>

    <!-- My Listings -->
    <div>
      <h4 class="fw-bold mb-4">Your Properties</h4>
      <% if (listings.length > 0) { %>
        <div class="row g-4">
          <% for(let listing of listings) { %>
            <div class="col-md-4">
              <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: var(--radius);">
                <img src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1580041066704-46c307477c5f?q=80&w=1170&auto=format&fit=crop' %>" class="card-img-top" style="height: 180px; object-fit: cover;" alt="Listing">
                <div class="card-body">
                  <h6 class="fw-bold mb-1"><%= listing.title %></h6>
                  <p class="text-muted small"><%= listing.location %></p>
                  <div class="d-flex gap-2">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-secondary flex-grow-1">Edit</a>
                    <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-dark flex-grow-1">View</a>
                  </div>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-center py-5 bg-light rounded-4">
          <p class="text-muted">No properties listed yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

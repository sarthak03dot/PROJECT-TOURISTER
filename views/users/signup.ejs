<% layout("/layouts/boilerplate") %>

<div class="auth-container mt-0">
  <div class="auth-image-side">
    <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?q=80&w=2070&auto=format&fit=crop" alt="Adventure">
    <div class="auth-image-overlay">
      <h1 class="display-4 fw-bold mb-3">Escape to the <br>nature.</h1>
      <p class="fs-5 text-light-50">Join thousands of travelers sharing their unique discoveries.</p>
    </div>
  </div>
  
  <div class="auth-form-side">
    <div class="auth-card fade-in">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-2">Create Account</h2>
        <p class="text-muted">Start your journey with TripTales today</p>
      </div>

      <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="form-floating mb-3">
          <input
            name="username"
            type="text"
            class="form-control bg-light border-0 shadow-none px-4"
            id="usernameInput"
            placeholder="Username"
            required
          />
          <label for="usernameInput" class="px-4">Username</label>
        </div>

        <div class="form-floating mb-3">
          <input
            name="email"
            type="email"
            class="form-control bg-light border-0 shadow-none px-4"
            id="emailInput"
            placeholder="Email"
            required
          />
          <label for="emailInput" class="px-4">Email</label>
        </div>

        <div class="form-floating mb-4 position-relative">
          <input
            name="password"
            type="password"
            class="form-control bg-light border-0 shadow-none px-4"
            id="passwordInput"
            placeholder="Password"
            required
          />
          <label for="passwordInput" class="px-4">Password</label>
          <span class="password-toggle">
            <i class="fa-solid fa-eye"></i>
          </span>
        </div>

        <button class="btn btn-primary-custom w-100 py-3 fw-bold rounded-pill mb-4 shadow-sm">
          Create Account
        </button>
      </form>

      <div class="text-center">
        <p class="text-muted small">Already part of TripTales? <a href="/signin" class="text-primary text-decoration-none fw-bold">Sign In</a></p>
      </div>
    </div>
  </div>
</div>

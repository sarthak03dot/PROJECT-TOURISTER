<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5 fade-in">
  <div class="col-lg-8 offset-lg-2">
    <div class="card shadow-sm border-0 p-4 p-md-5" style="border-radius: var(--radius);">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Host your stay</h2>
        <p class="text-muted">Share your wonderful place with travelers from around the world</p>
      </div>

      <form
        method="POST"
        action="/listings"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mb-4">
          <label for="title" class="form-label small fw-bold text-uppercase">Listing Title</label>
          <input
            name="listing[title]"
            id="title"
            placeholder="e.g. Cozy Beachfront Villa"
            type="text"
            class="form-control form-control-lg bg-light border-0 shadow-none"
            required
          />
          <div class="invalid-feedback">Please provide a catchy title.</div>
        </div>

        <div class="mb-4">
          <label for="description" class="form-label small fw-bold text-uppercase">Description</label>
          <textarea
            name="listing[description]"
            id="description"
            class="form-control bg-light border-0 shadow-none"
            placeholder="Tell us what makes your place special..."
            rows="5"
            required
          ></textarea>
          <div class="invalid-feedback">A brief description helps guests find you.</div>
        </div>

        <div class="mb-4">
          <label for="image" class="form-label small fw-bold text-uppercase">Property Photo</label>
          <div class="input-group">
            <input
              name="listing[image]"
              id="image"
              class="form-control bg-light border-0 shadow-none p-3"
              type="file"
              required
            />
          </div>
          <p class="text-muted small mt-2"><i class="fa-solid fa-circle-info me-1"></i>High-quality photos increase your chances of booking.</p>
          <div class="invalid-feedback">Please upload a property photo.</div>
        </div>

        <div class="row">
          <div class="mb-4 col-md-6">
            <label for="location" class="form-label small fw-bold text-uppercase">Location</label>
            <input
              name="listing[location]"
              id="location"
              placeholder="e.g. Malibu, California"
              type="text"
              class="form-control bg-light border-0 shadow-none"
              required
            />
            <div class="invalid-feedback">Where is this beautiful place?</div>
          </div>

          <div class="mb-4 col-md-6">
            <label for="country" class="form-label small fw-bold text-uppercase">Country</label>
            <input
              name="listing[country]"
              id="country"
              placeholder="e.g. United States"
              type="text"
              class="form-control bg-light border-0 shadow-none"
              required
            />
            <div class="invalid-feedback">Please specify the country.</div>
          </div>
        </div>

        <div class="mb-5">
          <label for="category" class="form-label small fw-bold text-uppercase">Category</label>
          <select
            name="listing[category]"
            id="category"
            class="form-select bg-light border-0 shadow-none"
            required
          >
            <option value="" disabled selected>Select an atmosphere</option>
            <option value="Luxury">Luxury Stays</option>
            <option value="Beach">Beachfront</option>
            <option value="Pools">Amazing Pools</option>
            <option value="Jungle">Tropical/Jungle</option>
            <option value="Mountains">Mountains</option>
            <option value="Historical">Historical Homes</option>
            <option value="Camping">Camping</option>
            <option value="Cabins">Cabins</option>
            <option value="Apartment">Modern Apartment</option>
            <option value="Arctic">Arctic/Snow</option>
            <option value="Other">Other</option>
          </select>
          <div class="invalid-feedback">Helping guests find the right vibe.</div>
        </div>

        <div class="d-grid gap-2 col-md-8 mx-auto">
          <button class="btn btn-primary-custom btn-lg py-3 shadow-sm">Create Listing</button>
          <a href="/listings" class="btn btn-link text-muted text-decoration-none small">Cancel and go back</a>
        </div>
      </form>
    </div>
  </div>
</div>
<script src="../../public/js/script.js"></script>

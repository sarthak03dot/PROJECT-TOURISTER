<% layout("/layouts/boilerplate") %>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div id="filters" class="d-flex align-items-center pb-2 px-1 gap-4 overflow-x-auto text-nowrap hide-scrollbar flex-grow-1" style="max-width: 80%;">
        <a href="/listings" class="filter text-decoration-none d-block text-center <%= !selectedCategory ? 'active' : '' %>" style="min-width: 60px;">
            <i class="fa-solid fa-house d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">All</span>
        </a>
        <a href="/listings/search?category=Luxury" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Luxury' ? 'active' : '' %>">
            <i class="fa-solid fa-crown d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Luxury</span>
        </a>
        <a href="/listings/search?category=Beach" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Beach' ? 'active' : '' %>">
            <i class="fa-solid fa-umbrella-beach d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Beach</span>
        </a>
        <a href="/listings/search?category=Pools" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Pools' ? 'active' : '' %>">
            <i class="fa-solid fa-person-swimming d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Pools</span>
        </a>
        <a href="/listings/search?category=Jungle" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Jungle' ? 'active' : '' %>">
            <i class="fa-solid fa-tree d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Jungle</span>
        </a>
        <a href="/listings/search?category=Mountains" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
            <i class="fa-solid fa-mountain d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Mountains</span>
        </a>
        <a href="/listings/search?category=Historical" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Historical' ? 'active' : '' %>">
            <i class="fa-solid fa-building-columns d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Historical</span>
        </a>
        <a href="/listings/search?category=Camping" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Camping' ? 'active' : '' %>">
            <i class="fa-solid fa-tent d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Camping</span>
        </a>
        <a href="/listings/search?category=Cabins" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Cabins' ? 'active' : '' %>">
            <i class="fa-solid fa-house-chimney d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Cabins</span>
        </a>
        <a href="/listings/search?category=Apartment" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Apartment' ? 'active' : '' %>">
            <i class="fa-solid fa-building d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Apartment</span>
        </a>
        <a href="/listings/search?category=Arctic" class="filter text-decoration-none d-block text-center <%= selectedCategory === 'Arctic' ? 'active' : '' %>">
            <i class="fa-solid fa-snowflake d-block mb-1 fs-5"></i>
            <span class="small fw-semibold">Arctic</span>
        </a>
    </div>

    <div class="tax-toggle border p-3 rounded-4 shadow-sm d-flex align-items-center bg-white">
        <div class="form-check form-switch form-check-reverse m-0 p-0 d-flex align-items-center gap-2">
            <label class="form-check-label fw-semibold small cursor-pointer" for="taxToggle" style="white-space: nowrap;">Display total after taxes</label>
            <input class="form-check-input mt-0 cursor-pointer shadow-none" type="checkbox" role="switch" id="taxToggle" style="width: 2.5rem; height: 1.25rem;">
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
  <% for(let listing of allListings){ %>
    <div class="col listing-col" data-category="<%= listing.category %>">
      <a href="/listings/<%= listing._id %>" class="text-decoration-none">
        <div class="card listing-card h-100 border-0">
          <div class="position-relative overflow-hidden" style="border-radius: var(--radius);">
            <img
              src="<%= listing.image.url %>"
              class="card-img-top"
              alt="<%= listing.title %>"
              loading="lazy"
            />
            <div class="card-img-overlay d-flex align-items-start justify-content-end p-3">
              <button 
                class="btn btn-light btn-sm rounded-circle shadow-sm wishlist-btn" 
                data-id="<%= listing._id %>"
                style="width: 32px; height: 32px; padding: 0;"
                onclick="toggleWishlist(event, '<%= listing._id %>')"
              >
                <i class="<%= (currUser && currUser.wishlist && currUser.wishlist.includes(listing._id)) ? 'fa-solid text-danger' : 'fa-regular' %> fa-heart"></i>
              </button>
            </div>
          </div>

          <div class="card-body px-1 py-3">
            <div class="d-flex justify-content-between align-items-start">
              <h5 class="card-title text-truncate mb-0" style="max-width: 80%;"><%= listing.title %></h5>
              <div class="d-flex align-items-center small fw-bold">
                <i class="fa-solid fa-star text-warning me-1" style="font-size: 0.8rem;"></i>
                <span>New</span>
              </div>
            </div>
            <p class="card-text text-muted mb-1 small">
              <%= listing.location %>, <%= listing.country %>
            </p>
            <div class="mt-2 d-flex align-items-center">
              <span class="fw-bold text-white base-price">$<%= listing.price.toLocaleString("en-IN") %> <span class="text-muted small fw-normal">/ night</span></span>
              <span class="fw-bold text-white tax-price d-none">$<%= (listing.price * 1.18).toLocaleString("en-IN") %> <span class="text-muted small fw-normal">total after taxes</span></span>
            </div>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<style>
  .filters-container {
    position: sticky;
    top: 4.5rem;
    z-index: 10;
    background: var(--bg-main);
    border-bottom: 1px solid #e2e8f0;
    margin: 0 -1.5rem;
    padding: 0 1.5rem;
  }

  .filters {
    display: flex;
    overflow-x: auto;
    gap: 2rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: fit-content;
    opacity: 0.7;
    border-bottom: 2px solid transparent;
    padding-bottom: 0.5rem;
  }

  .filter i {
    font-size: 1.4rem;
  }

  .filter span {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .filter:hover, .filter.active {
    opacity: 1;
    color: var(--primary);
  }

  .filter.active {
    border-bottom-color: var(--primary);
  }

  .listing-col {
    transition: all 0.3s ease;
  }
</style>

<script>
    async function toggleWishlist(event, id) {
        event.preventDefault();
        event.stopPropagation();
        
        const btn = event.currentTarget; // Capture button early
        const icon = btn.querySelector('i');
        
        try {
            const response = await fetch(`/wishlist/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            if (response.status === 401 || response.url.includes('/signin')) {
                window.location.href = '/signin';
                return;
            }
            
            const data = await response.json();
            if (data.success) {
                if (data.added) {
                    icon.classList.remove('fa-regular');
                    icon.classList.add('fa-solid', 'text-danger');
                    // Add a little pop animation
                    icon.style.transform = 'scale(1.3)';
                    setTimeout(() => icon.style.transform = 'scale(1)', 200);
                } else {
                    icon.classList.remove('fa-solid', 'text-danger');
                    icon.classList.add('fa-regular');
                }
            }
        } catch (err) {
            console.error('Wishlist error:', err);
        }
    }

    // Tax Toggle Logic
    const taxToggle = document.getElementById('taxToggle');
    taxToggle.addEventListener('change', () => {
        const basePrices = document.querySelectorAll('.base-price');
        const taxPrices = document.querySelectorAll('.tax-price');
        
        basePrices.forEach(el => {
            el.classList.toggle('d-none');
        });
        taxPrices.forEach(el => {
            el.classList.toggle('d-none');
            if (!el.classList.contains('d-none')) {
                el.classList.add('fade-in');
            }
        });
    });
</script>

<!-- Client-side script removed in favor of server-side filtering -->

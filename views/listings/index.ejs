<% layout("/layouts/boilerplate") %>

<!-- Filter Section -->
<div class="filters-container mb-4">
  <div class="filters py-3" id="filters">
    <div class="filter active" data-category="all">
      <i class="fa-solid fa-fire"></i>
      <span>Trending</span>
    </div>
    <div class="filter" data-category="Luxury">
      <i class="fa-solid fa-gem"></i>
      <span>Luxury</span>
    </div>
    <div class="filter" data-category="Beach">
      <i class="fa-solid fa-umbrella-beach"></i>
      <span>Beachfront</span>
    </div>
    <div class="filter" data-category="Pools">
      <i class="fa-solid fa-person-swimming"></i>
      <span>Amazing Pools</span>
    </div>
    <div class="filter" data-category="Jungle">
      <i class="fa-solid fa-tree"></i>
      <span>Tropical</span>
    </div>
    <div class="filter" data-category="Historical">
      <i class="fa-solid fa-landmark"></i>
      <span>Historical</span>
    </div>
    <div class="filter" data-category="Mountains">
      <i class="fa-solid fa-mountain"></i>
      <span>Mountains</span>
    </div>
    <div class="filter" data-category="Camping">
      <i class="fa-solid fa-campground"></i>
      <span>Camping</span>
    </div>
    <div class="filter" data-category="Castles">
      <i class="fa-solid fa-chess-rook"></i>
      <span>Castles</span>
    </div>
    <div class="filter" data-category="Arctic">
      <i class="fa-solid fa-snowflake"></i>
      <span>Arctic</span>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
  <% for(let listing of allListings){ %>
    <div class="col listing-col" data-category="<%= listing.category %>">
      <a href="/listings/<%= listing._id %>" class="text-decoration-none">
        <div class="card listing-card h-100 border-0">
          <div class="position-relative overflow-hidden" style="border-radius: var(--radius);">
            <img
              src="<%= listing.image.url %>"
              class="card-img-top"
              alt="<%= listing.title %>"
              loading="lazy"
            />
            <div class="card-img-overlay d-flex align-items-start justify-content-end p-3">
              <button class="btn btn-light btn-sm rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;">
                <i class="fa-regular fa-heart"></i>
              </button>
            </div>
          </div>

          <div class="card-body px-1 py-3">
            <div class="d-flex justify-content-between align-items-start">
              <h5 class="card-title text-truncate mb-0" style="max-width: 80%;"><%= listing.title %></h5>
              <div class="d-flex align-items-center small fw-bold">
                <i class="fa-solid fa-star text-warning me-1" style="font-size: 0.8rem;"></i>
                <span>New</span>
              </div>
            </div>
            <p class="card-text text-muted mb-1 small">
              <%= listing.location %>, <%= listing.country %>
            </p>
            <div class="mt-2 d-flex align-items-center">
              <span class="fw-bold text-dark">$<%= Math.floor(Math.random() * (500 - 50 + 1)) + 50 %></span>
              <span class="text-muted small ms-1">/ night</span>
            </div>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<style>
  .filters-container {
    position: sticky;
    top: 4.5rem;
    z-index: 10;
    background: var(--bg-main);
    border-bottom: 1px solid #e2e8f0;
    margin: 0 -1.5rem;
    padding: 0 1.5rem;
  }

  .filters {
    display: flex;
    overflow-x: auto;
    gap: 2rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: fit-content;
    opacity: 0.7;
    border-bottom: 2px solid transparent;
    padding-bottom: 0.5rem;
  }

  .filter i {
    font-size: 1.4rem;
  }

  .filter span {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .filter:hover, .filter.active {
    opacity: 1;
    color: var(--primary);
  }

  .filter.active {
    border-bottom-color: var(--primary);
  }

  .listing-col {
    transition: all 0.3s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = document.querySelectorAll('.filter');
    const items = document.querySelectorAll('.listing-col');

    filters.forEach(filter => {
      filter.addEventListener('click', () => {
        // Update active class
        filters.forEach(f => f.classList.remove('active'));
        filter.classList.add('active');

        const category = filter.getAttribute('data-category');

        items.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            item.style.display = 'block';
            setTimeout(() => item.style.opacity = '1', 10);
          } else {
            item.style.opacity = '0';
            setTimeout(() => item.style.display = 'none', 300);
          }
        });
      });
    });
  });
</script>

<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5 fade-in">
  <div class="col-lg-8 offset-lg-2">
    <div class="card shadow-sm border-0 p-4 p-md-5" style="border-radius: var(--radius);">
      <div class="text-center mb-5">
        <h2 class="fw-bold text-secondary">Edit your listing</h2>
        <p class="text-muted">Keep your property details up to date for your guests</p>
      </div>

      <form
        method="POST"
        action="/listings/<%= listing._id %>?_method=PUT"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mb-4">
          <label for="title" class="form-label small fw-bold text-uppercase">Listing Title</label>
          <input
            name="listing[title]"
            id="title"
            value="<%= listing.title %>"
            type="text"
            class="form-control form-control-lg bg-light border-0 shadow-none"
            required
          />
          <div class="invalid-feedback">Title is required.</div>
        </div>

        <div class="mb-4">
          <label for="description" class="form-label small fw-bold text-uppercase">Description</label>
          <textarea
            name="listing[description]"
            id="description"
            class="form-control bg-light border-0 shadow-none"
            rows="5"
            required
          ><%= listing.description %></textarea>
        </div>

        <div class="row mb-4 align-items-center">
          <div class="col-md-4">
            <label class="form-label small fw-bold text-uppercase">Current Image</label>
            <div class="rounded-3 overflow-hidden border shadow-sm" style="height: 120px;">
              <img src="<%= OriginalImageUrl %>" class="w-100 h-100 object-fit-cover" alt="Original Image">
            </div>
          </div>
          <div class="col-md-8">
            <label for="image" class="form-label small fw-bold text-uppercase">Replace Image</label>
            <input
              name="listing[image]"
              id="image"
              class="form-control bg-light border-0 shadow-none p-2"
              type="file"
            />
            <p class="text-muted small mt-2 mb-0">Leave blank to keep the current image.</p>
          </div>
        </div>

        <div class="row">
          <div class="mb-4 col-md-6">
            <label for="location" class="form-label small fw-bold text-uppercase">Location</label>
            <input
              name="listing[location]"
              id="location"
              value="<%= listing.location %>"
              type="text"
              class="form-control bg-light border-0 shadow-none"
              required
            />
          </div>

          <div class="mb-4 col-md-6">
            <label for="country" class="form-label small fw-bold text-uppercase">Country</label>
            <input
              name="listing[country]"
              id="country"
              value="<%= listing.country %>"
              type="text"
              class="form-control bg-light border-0 shadow-none"
              required
            />
          </div>
        </div>

        <div class="mb-5">
          <label for="category" class="form-label small fw-bold text-uppercase">Category</label>
          <select
            name="listing[category]"
            id="category"
            class="form-select bg-light border-0 shadow-none"
            required
          >
            <option value="Luxury" <%= listing.category === 'Luxury' ? 'selected' : '' %>>Luxury Stays</option>
            <option value="Beach" <%= listing.category === 'Beach' ? 'selected' : '' %>>Beachfront</option>
            <option value="Pools" <%= listing.category === 'Pools' ? 'selected' : '' %>>Amazing Pools</option>
            <option value="Jungle" <%= listing.category === 'Jungle' ? 'selected' : '' %>>Tropical/Jungle</option>
            <option value="Mountains" <%= listing.category === 'Mountains' ? 'selected' : '' %>>Mountains</option>
            <option value="Historical" <%= listing.category === 'Historical' ? 'selected' : '' %>>Historical Homes</option>
            <option value="Camping" <%= listing.category === 'Camping' ? 'selected' : '' %>>Camping</option>
            <option value="Cabins" <%= listing.category === 'Cabins' ? 'selected' : '' %>>Cabins</option>
            <option value="Apartment" <%= listing.category === 'Apartment' ? 'selected' : '' %>>Modern Apartment</option>
            <option value="Arctic" <%= listing.category === 'Arctic' ? 'selected' : '' %>>Arctic/Snow</option>
            <option value="Other" <%= listing.category === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>

        <div class="d-grid gap-2 col-md-8 mx-auto">
          <button class="btn btn-primary-custom btn-lg py-3 shadow-sm">Save Changes</button>
          <a href="/listings/<%= listing._id %>" class="btn btn-link text-muted text-decoration-none small">Cancel changes</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="../../public/js/script.js"></script>

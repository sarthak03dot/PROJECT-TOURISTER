<% if(locals.success && locals.success.length) {%>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      showToast("<%= locals.success %>", "success");
    });
  </script>
<% } %>

<% if(locals.error && locals.error.length) {%>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      showToast("<%= locals.error %>", "error");
    });
  </script>
<% } %>
    
<% if(success && success.length) {%>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      showToast("<%= success %>", "success");
    });
  </script>
<% } %>

<% if(error && error.length) {%>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      showToast("<%= error %>", "error");
    });
  </script>
<% } %>
    
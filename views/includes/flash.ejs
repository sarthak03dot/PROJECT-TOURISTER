<% if(success && success.length) {%>
<div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mx-auto mb-4 d-flex align-items-center" role="alert" style="border-radius: 0.75rem; max-width: 600px;">
  <i class="fa-solid fa-circle-check me-2 fs-5"></i>
  <div><%= success %></div>
  <button
    class="btn-close shadow-none"
    type="button"
    data-bs-dismiss="alert"
    aria-label="close"
  ></button>
</div>
<% } %>

<% if(error && error.length) {%>
<div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mx-auto mb-4 d-flex align-items-center" role="alert" style="border-radius: 0.75rem; max-width: 600px;">
  <i class="fa-solid fa-circle-exclamation me-2 fs-5"></i>
  <div><%= error %></div>
  <button
    class="btn-close shadow-none"
    type="button"
    data-bs-dismiss="alert"
    aria-label="close"
  ></button>
</div>
<% } %>
    